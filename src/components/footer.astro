---
// Fetch the current year dynamically to keep the copyright up to date
const year = new Date().getFullYear()
---

<!-- MAIN FOOTER CONTAINER: Styled with a custom sage background, dark slate text, and top border -->
<footer class="bg-[#D1D5BE] text-[#2F4340] py-12 px-6 border-t border-white/20">
  
  <!-- TWO-COLUMN RESPONSIVE GRID: Stacked on mobile (grid-cols-1), split 50/50 on desktop (md:grid-cols-2) -->
  <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
    
    <!-- LEFT COLUMN: Brand Identity & Sister Company Navigation Links -->
    <div class="flex flex-col items-center md:items-start">
      <div class="flex flex-col items-start max-w-xs pl-4">
        
        <!-- Logo Wrap -->
        <div class="w-48 mb-4">
          <img 
            loading="lazy" 
            src="/Logos/quality-companies.png" 
            id="quality-logo" 
            alt="Quality Companies Logo"
            class="w-full h-auto object-contain"
          />
        </div>

        <!-- Multi-Company Navigation Menu: Highlighted active site with custom accent color -->
        <div class="border-l-2 border-white/60 pl-4 py-1 w-full">
          <ul class="flex flex-col space-y-2 text-lg font-bold text-[#2F4340]/90 tracking-wide">
            <!-- Active Site Indicator -->
            <li class="text-[#D9744B] drop-shadow-sm font-extrabold" aria-label="Current Website: Quality Landscape and Leisure">
              Landscape & Leisure
            </li>
            <!-- Sister Brand External Links -->
            <li>
              <a href="https://qualityelectricofindiana.com/" aria-label="Quality Electric" class="hover:text-[#D9744B] transition-colors block">Electric</a>
            </li>
            <li>
              <a href="https://www.qualityroofingofindiana.com/" aria-label="Quality Roofing" class="hover:text-[#D9744B] transition-colors block">Roofing</a>
            </li>
            <li>
              <a href="https://www.southardhomesllc.com" target="_blank" rel="noopener noreferrer" aria-label="New Construction - Southard Homes LLC" class="hover:text-[#D9744B] transition-colors block">New Construction</a>
            </li>
            <li>
              <a href="https://www.southardhomesllc.com" target="_blank" rel="noopener noreferrer" aria-label="Remodels - Southard Homes LLC" class="hover:text-[#D9744B] transition-colors block">Remodels</a>
            </li>
            <li>
              <a href="https://www.southardhomesllc.com" target="_blank" rel="noopener noreferrer" aria-label="Rentals - Southard Homes LLC" class="hover:text-[#D9744B] transition-colors block">Rentals</a>
            </li>
          </ul>
        </div>

      </div>
    </div>

    <!-- RIGHT COLUMN: Contact Channels, Location Data, and Metadata Stack -->
    <div class="space-y-6 max-w-md mx-auto md:mx-0 w-full">
      
      <!-- Card 1: Social Media Channel Integrations -->
      <div class="bg-white/30 p-4 rounded-2xl border border-white/30 shadow-sm">
        <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-3 text-center md:text-left">Connect With Us</span>
        <div class="flex items-center justify-center md:justify-start gap-4">
          <!-- Facebook Link -->
          <a href="#" target="_blank" rel="noopener noreferrer" class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-all shadow-sm" aria-label="Follow us on Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/>
            </svg>
          </a>
          <!-- Instagram Link -->
          <a href="#" target="_blank" rel="noopener noreferrer" class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-all shadow-sm" aria-label="Follow us on Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <!-- YouTube Link -->
          <a href="#" target="_blank" rel="noopener noreferrer" class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-all shadow-sm" aria-label="Subscribe on YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Card 2: Click-to-Call Phone Communication Routing -->
      <div class="flex items-center gap-4 bg-white/30 p-3.5 rounded-2xl border border-white/30 shadow-sm">
        <a href="tel:812-244-9432" class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-all shrink-0 block" aria-label="Call Office">
          <svg xmlns="http://www.w3.org/2000/xl" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 0 1-7.108-7.108c-.155-.44.011-.927.387-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
        </a>
        <div>
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-0.5">Call Us</span>
          <a href="tel:812-244-9432" class="text-lg font-extrabold hover:text-[#D9744B] transition-colors block">812-244-9432</a>
        </div>
      </div>

      <!-- Card 3: Inbound Corporate Email Configuration -->
      <div class="flex items-center gap-4 bg-white/30 p-3.5 rounded-2xl border border-white/30 shadow-sm">
        <a href="mailto:quadup79@gmail.com" class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-all shrink-0 block" aria-label="Email Office">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </a>
        <div class="break-all">
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-0.5">Email Us</span>
          <a href="mailto:quadup79@gmail.com" class="text-base font-bold hover:text-[#D9744B] transition-colors block">quadup79@gmail.com</a>
        </div>
      </div>

      <!-- Card 4: Office Mapping Coordinates & Physical Address -->
      <div class="flex items-center gap-4 bg-white/30 p-3.5 rounded-2xl border border-white/30 shadow-sm">
        <a 
          href="https://www.google.com/maps?q=3601+N+Fruitridge+Avenue+Terre+Haute+IN+47805" 
          target="_blank" 
          rel="noopener noreferrer"
          class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-all shrink-0 block"
          aria-label="Open Map Location"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
        </a>
        <div>
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-0.5">Visit Our Office</span>
          <a 
            href="https://www.google.com/maps?q=3601+N+Fruitridge+Avenue+Terre+Haute+IN+47805" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-sm font-bold hover:text-[#D9744B] transition-colors block leading-snug"
          >
            3601 N. Fruitridge Avenue<br />Terre Haute, IN 47805
          </a>
        </div>
      </div>

      <!-- Card 5: Core Operations Schedule & Geolocation Parameters -->
      <div class="bg-white/30 p-4 rounded-2xl border border-white/30 shadow-sm text-xs text-slate-800 font-medium space-y-2.5">
        <div>
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-1">Hours</span>
          <p class="text-sm font-bold text-[#2F4340]">8am - 4pm | Monday to Friday</p>
        </div>
        <div class="border-t border-[#2F4340]/10 pt-2.5">
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-1">Service Areas</span>
          <p class="leading-relaxed text-[#2F4340]/90">
            Proudly serving Vigo, Parke, Vermillion, Sullivan, Greene, and Knox Counties.
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- ROW SECTION 1: Standard Corporate Copyright Framework Layer -->
  <div class="mt-12 pt-6 border-t border-dashed border-[#2F4340]/20 text-center text-xs text-slate-700 font-medium">
    © <span>{year}</span> Quality Landscape and Leisure of Indiana, LLC. All rights reserved.
  </div>

  <!-- ROW SECTION 2: Production & Management Attribution Layer -->
  <p class="text-gray-600 flex items-start pt-4 pb-6 justify-center">
    Website by <img class="px-2 h-5 inline-block drop-shadow-sm" alt="Monarch Media LLC" src="https://i.postimg.cc/yxKgn2TG/Monarch-inline-col.png">
  </p>
</footer>

<style>
  footer {
    padding: 2rem 2rem 1rem 2rem;
    display: flex;
    flex-direction: column;
  }

  .footer-head {
    text-align: left;
  }

  .biz-info-and-companies {
    display: flex;
    flex-direction: row;
    justify-content: center;
  }

  .biz-info {
    font-size: 1rem;
  }

  .quality-description p {
    display: none;
  }

  .quality-companies {
    padding-bottom: 0!important;
    justify-content: center;
    align-items: center;
    padding: 0 0 1rem 0!important;
    width: auto!important;
    min-width: 20rem!important;
  }

  .socials {
    display: flex;
    gap: 1rem;
  }
</style>