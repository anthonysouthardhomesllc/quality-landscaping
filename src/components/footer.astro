---
//footer.astro
//Global footer composition containing centralized dynamic NAP validation data and LocalBusiness JSON-LD schema tracking.

import { Image } from 'astro:assets';

//Import local footer branding to enable build-time image compression and optimization pipelines
import companiesLogo from "../assets/Logos/quality-companies.png";

const year = new Date().getFullYear();

//Centralized schema data object to keep HTML tokens and JSON-LD structured layers synchronized
const businessData = {
  name: "Quality Landscape and Leisure of Indiana, LLC",
  phone: "812-244-9432",
  email: "quadup79@gmail.com",
  address: "3601 N. Fruitridge Avenue",
  city: "Terre Haute",
  state: "IN",
  zip: "47805",
  url: "https://qualitylandscapeandleisure.com", //TODO Replace with your domain once finalized
  mapUrl: "https://www.google.com/maps?q=3601+N+Fruitridge+Avenue+Terre+Haute+IN+47805"
};

//Formatted schema injection string targeting Google's rich snippets engine
const jsonLdSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LandscapingService",
  "name": businessData.name,
  "telephone": businessData.phone,
  "email": businessData.email,
  "url": businessData.url,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": businessData.address,
    "addressLocality": businessData.city,
    "addressRegion": businessData.state,
    "postalCode": businessData.zip,
    "addressCountry": "US"
  }
});
---

<!-- Schema Markup Injection - Hidden from user UI but parsed directly by search spiders -->
<script is:inline type="application/ld+json" set:html={jsonLdSchema}></script>

<footer class="bg-[#D1D5BE] text-[#2F4340] py-12 px-6 border-t border-white/20 mt-auto">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start md:justify-between w-full">  
    
    <!-- LEFT COLUMN: Brand Identity & Cross-Domain Sister Brand Network Maps -->
    <div class="flex flex-col items-center md:items-start">
      <div class="flex flex-col items-start max-w-xs pl-0 md:pl-4">
        
        <!-- Logo Wrapper -->
        <div class="w-48 mb-4">
          <Image 
            src={companiesLogo}
            alt="Quality Companies of Indiana umbrella organization logo"
            width={192}
            height={64}
            class="w-full h-auto object-contain"
            loading="lazy"
          />
        </div>

        <!-- Cross-Domain Authority List: Boosts crawling visibility across corporate digital footprints -->
        <nav class="border-l-2 border-white/60 pl-4 py-1 w-full" aria-label="Our Sister Companies">
          <ul class="flex flex-col space-y-2 text-lg font-bold text-[#2F4340]/90 tracking-wide">
            <li class="text-[#D9744B] drop-shadow-sm font-extrabold" aria-current="page">
              Landscape & Leisure
            </li>
            <li>
              <a href="https://qualityelectricofindiana.com/" aria-label="Quality Electric of Indiana" 
                class="hover:text-[#D9744B] transition-colors block">Electric</a>
            </li>
            <li>
              <a href="https://www.qualityroofingofindiana.com/" aria-label="Quality Roofing of Indiana" 
                class="hover:text-[#D9744B] transition-colors block">Roofing</a>
            </li>
            <li>
              <a href="https://www.southardhomesllc.com" target="_blank" rel="noopener noreferrer" aria-label="Southard Homes LLC - New Construction Division" 
                class="hover:text-[#D9744B] transition-colors block">New Construction</a>
            </li>
            <li>
              <a href="https://www.southardhomesllc.com" target="_blank" rel="noopener noreferrer" aria-label="Southard Homes LLC - Remodeling Services" 
                class="hover:text-[#D9744B] transition-colors block">Remodels</a>
            </li>
            <li>
              <a href="https://www.southardhomesllc.com" target="_blank" rel="noopener noreferrer" aria-label="Southard Homes LLC - Residential Rental Portfolio" 
                class="hover:text-[#D9744B] transition-colors block">Rentals</a>
            </li>
          </ul>
        </nav>

      </div>
    </div>

    <!-- RIGHT COLUMN: Targeted Contact Routing Points (NAP Signal Consistency) -->
    <div class="space-y-6 max-w-md mx-auto md:mx-0 w-full">
      
      <!-- Card 1: Social Channel Hub Links -->
      <div class="bg-white/30 p-4 rounded-2xl border border-white/30 shadow-sm">
        <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-3 text-center md:text-left">Connect With Us</span>
        <div class="flex items-center justify-center md:justify-start gap-4">
          <a href="#" target="_blank" rel="noopener noreferrer" 
            class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#D9744B] hover:text-white transition-all shadow-sm" aria-label="Follow us on Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/>
            </svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" 
            class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#D9744B] hover:text-white transition-all shadow-sm" aria-label="Follow us on Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" 
            class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#D9744B] hover:text-white transition-all shadow-sm" aria-label="Subscribe to our channel on YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Card 2: Click-to-Call Phone Communication Anchor -->
      <div class="flex items-center gap-4 bg-white/30 p-3.5 rounded-2xl border border-white/30 shadow-sm">
        <a href={`tel:${businessData.phone}`} class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#D9744B] hover:text-white transition-all shrink-0 block" aria-label="Call Office Phone Line">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 0 1-7.108-7.108c-.155-.44.011-.927.387-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
        </a>
        <div>
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-0.5">Call Ray</span>
          <a href={`tel:${businessData.phone}`} class="text-lg font-extrabold hover:text-[#D9744B] transition-colors block">{businessData.phone}</a>
        </div>
      </div>

      <!-- Card 3: Interactive Inbound Corporate Email -->
      <div class="flex items-center gap-4 bg-white/30 p-3.5 rounded-2xl border border-white/30 shadow-sm">
        <a href={`mailto:${businessData.email}`} class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#D9744B] hover:text-white transition-all shrink-0 block" aria-label="Send Corporate Email Inquiry">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </a>
        <div class="break-all">
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-0.5">Email Ray</span>
          <a href={`mailto:${businessData.email}`} class="text-base font-bold hover:text-[#D9744B] transition-colors block">{businessData.email}</a>
        </div>
      </div>

      <!-- Card 4: Local Physical Coordinates Validation -->
      <div class="flex items-center gap-4 bg-white/30 p-3.5 rounded-2xl border border-white/30 shadow-sm">
        <a 
          href={businessData.mapUrl} 
          target="_blank" 
          rel="noopener noreferrer"
          class="bg-white p-2.5 rounded-xl text-[#2F4340] hover:bg-[#D9744B] hover:text-white transition-all shrink-0 block"
          aria-label="Open Office Headquarters Map Navigation Panel"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
        </a>
        <div>
          <span class="text-[10px] uppercase font-bold tracking-widest text-slate-700 block mb-0.5">Visit Our Office</span>
          <a 
            href={businessData.mapUrl} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-sm font-bold hover:text-[#D9744B] transition-colors block leading-snug"
          >
            {businessData.address}<br />{businessData.city}, {businessData.state} {businessData.zip}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Standard Corporate Copyright Framework Layer -->
  <div class="mt-12 pt-6 border-t border-dashed border-[#2F4340]/20 text-center text-xs text-slate-700 font-medium">
    &copy; <span>{year}</span> {businessData.name}. All rights reserved.
  </div>

  <!-- Production Attribution Layer -->
  <p class="text-gray-600 flex items-center pt-4 justify-center text-xs font-semibold">
    Website by 
    <img 
      class="pl-1.5 h-4 inline-block drop-shadow-sm filter brightness-95" 
      alt="Monarch Media LLC corporate service badge" 
      src="/Logos/Monarch.png"
    />
  </p>
</footer>