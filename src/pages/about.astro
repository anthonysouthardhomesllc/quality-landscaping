---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Container from "@components/container.astro";
import { Image } from 'astro:assets';
import type { teamProps } from "@scripts/TeamMemberInterfaces.ts";

const team: Array<teamProps> = [
  {
    name: "Ray LeClercq",
    title: "Sales Manager",
    avatar: {
      title: "Ray LeClercq Profile Picture",
      path: "https://i.postimg.cc/SNb1nW7r/Ray.jpg"
    }
  },
  {
    name: "Anthony Felker",
    title: "Web Developer",
    avatar: {
      title: "Anthony Felker Profile Picture",
      path: "https://i.postimg.cc/Z5yJc96k/Anthony.jpg"
    }
  },
];

//Targeted SEO copy configuration suite
const pageTitle = "About Our Landscaping Company | Quality Landscape & Leisure";
const pageDescription = "Learn about Quality Landscape and Leisure, a member of the Quality family of companies. We provide high-end hardscaping and residential landscape architecture across Terre Haute.";

//AboutPage Schema to define the structural identity of the page and team profiles
const aboutSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": pageTitle,
  "description": pageDescription,
  "mainEntity": {
    "@type": "LandscapingService",
    "name": "Quality Landscape and Leisure",
    "parentOrganization": {
      "@type": "LocalBusiness",
      "name": "Quality Electrical & Multi-Trade Family of Companies"
    },
    "employee": team.map(member => ({
      "@type": "Person",
      "name": member.name,
      "jobTitle": member.title
    }))
  }
});
---

<Layout title={pageTitle} description={pageDescription}>
  <script is:inline type="application/ld+json" set:html={aboutSchema}></script>

  <Container>
    <div id="container" class="py-16 md:py-24">
      <main class="space-y-20">
        
        <section id="hero" class="max-w-4xl mx-auto px-4 text-center">
          <div class="bg-white/60 backdrop-blur-sm p-6 md:p-10 rounded-2xl border 
           border-white/50 shadow-sm text-lg text-slate-800 font-medium 
           leading-relaxed space-y-6 text-left md:text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold text-[#2F4340] tracking-tight mb-2">
              About Us
            </h1>
            <div class="w-58 h-1 bg-[#D9744B] mx-auto rounded-full"></div>
            <p>
              At <strong>Quality Landscape and Leisure</strong>, we are dedicated to transforming your outdoor residential or commercial property into an inviting, high-end retreat. From custom hardscapes and lush turf installations to routine property maintenance, our standard is perfection.
            </p>
            <p>
              Backed by the trusted foundation of our multi-trade Quality family of companies serving the Wabash Valley, we bring unmatched reliability, structural expertise, and creative architectural landscaping design to every property we touch.
            </p>
          </div>
        </section>

        <section id="team" class="max-w-4xl mx-auto px-4">
          <div class="bg-white/60 backdrop-blur-sm p-6 md:p-10 rounded-2xl border
           border-white/50 shadow-sm text-lg text-slate-800 font-medium 
           leading-relaxed space-y-6 text-left md:text-center">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-extrabold text-[#2F4340] tracking-tight mb-2">
                Meet Our Team
              </h2>
              <div class="w-58 h-1 bg-[#D9744B] mx-auto rounded-full"></div>
            </div>

            <div class="flex flex-wrap justify-center gap-8 w-full">
              {
                team.map((member) => (
                  <div class="bg-[#D1D5BE]/40 backdrop-blur-sm rounded-2xl 
                   p-6 border border-white/40 shadow-sm text-center 
                   flex flex-col items-center group transition-all
                   duration-300 hover:shadow-md hover:-translate-y-1 w-full sm:w-[calc(50%-1rem)] md:w-[calc(33.333%-1.5rem)] max-w-3xs">
                  
                    <div class="w-32 h-32 rounded-2xl overflow-hidden 
                     mb-4 border-2 border-white shadow-inner bg-white/50">
                      <Image 
                        src={member.avatar.path} 
                        alt={member.avatar.title}
                        width={128}
                        height={128}
                        loading="lazy"
                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      />
                    </div>

                    <h3 class="text-xl font-bold text-[#2F4340] mb-1">
                      {member.name}
                    </h3>
                    <p class="text-sm font-semibold text-slate-600 uppercase tracking-wider">
                      {member.title}
                    </p>
                  
                  </div>
                ))
              }
            </div>
          </div>
        </section>
      </main>
    </div>
  </Container>
</Layout>