---
// src/components/Welcome.astro
import WhyUs from "./WhyUs.astro";
import GalleryDisplay from "@components/gallery-display.astro";

//Complete LocalBusiness schema data to pass explicit signal graphs to indexing crawlers
const homeSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LandscapingService",
  "name": "Quality Landscape and Leisure",
  "image": new URL("/opengraph.jpg", Astro.site).toString(),
  "telephone": "812-244-9432",
  "email": "quadup79@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3601 N. Fruitridge Avenue",
    "addressLocality": "Terre Haute",
    "addressRegion": "IN",
    "postalCode": "47805",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "39.506166",
    "longitude": "-87.357866"
  },
  "url": Astro.site?.toString() || "https://qualitylandscapeandleisure.com",
  "areaServed": [
    {
      "@type": "City",
      "name": "Terre Haute",
      "sameAs": "https://en.wikipedia.org/wiki/Terre_Haute,_Indiana"
    },
    {
      "@type": "Place",
      "name": "Wabash Valley"
    }
  ],
  "priceRange": "$$"
});
---

<!-- Embed local search graph node data right into the home layout initialization stream -->
<script is:inline type="application/ld+json" set:html={homeSchema}></script>

<div id="container" class="py-16 md:py-20 text-center px-4">
  <main>
    <section id="hero" class="max-w-3xl mx-auto">
      <!-- Premium Glass Backing Panel for Flawless Readability over Background Images -->
      <div class="bg-[#D1D5BE]/60 backdrop-blur-lg rounded-3xl p-8 md:px-14 md:py-10
        shadow-xl border border-white/40 max-w-2xl mx-auto">
        
        <!-- Main SEO Heading enriched with location and service tags -->
        <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-none mb-6">
          <span class="block text-[#D9744B] drop-shadow-[0_2px_2px_rgba(255,255,255,0.8)]">
            QUALITY LANDSCAPE
          </span>
          <span class="block text-sm md:text-lg font-bold text-[#2F4340] tracking-[0.3em] my-2 uppercase opacity-80">
            — and —
          </span>
          <span class="block text-[#D9744B] drop-shadow-[0_2px_2px_rgba(255,255,255,0.8)]">
            LEISURE
          </span>
          <!-- Screen reader / Crawler optimization: Bridges brand with local search terms -->
          <span class="sr-only"> - Landscaping and Hardscaping Services in Terre Haute, Indiana</span>
        </h1>
        
        <!-- Subtitle Descriptor with geographic anchor -->
        <p class="text-xl md:text-2xl font-bold text-[#2F4340] tracking-wide mb-8 drop-shadow-[0_1px_1px_rgba(255,255,255,0.6)]">
          Professional Landscaping, Hardscaping & Outdoor Design in Terre Haute & The Wabash Valley.
        </p>

        <!-- Dynamic Call to Actions -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a 
            href="/services" 
            class="w-full sm:w-auto bg-[#2F4340] text-white 
              font-bold px-8 py-3.5 rounded-xl shadow-md 
              hover:bg-[#D9744B] hover:border-slate-200 hover:border
              transition-colors duration-200 text-base"
          >
            Our Services
          </a>
          <a 
            href="/contact" 
            class="w-full sm:w-auto bg-white/80 backdrop-blur-sm 
              text-[#2F4340] border border-slate-200 font-bold px-8 
              py-3.5 rounded-xl shadow-sm hover:bg-[#D9744B] transition-colors 
              duration-200 text-base"
          >
            Get a Quote
          </a>
        </div>
      </div>
    </section>

    <section>
      <!-- Why Us Content -->
      <div class="bg-[#D1D5BE]/60 backdrop-blur-lg rounded-3xl p-8 md:p-14 shadow-xl border border-white/40 max-w-4xl mx-auto mt-16">
        <WhyUs />
      </div>      
    </section>

    <section class="max-w-6xl mx-auto px-4 py-10">
      <!-- Gallery Preview -->
      <div class="max-w-6xl mx-auto text-center mb-10 overflow-hidden 
        rounded-2xl bg-[#D1D5BE]/80 backdrop-blur-md p-8 md:p-12 border-white/40 border">
        <div>
          
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-[#2F4340] mb-3">
          Recent Projects
        </h2>
        <p class="text-[#2F4340] font-semibold pb-4">
          Browse a selection of landscaping, hardscaping, and outdoor living
          projects completed throughout Terre Haute and the Wabash Valley.
        </p>

        <GalleryDisplay limit={6} columns={2} />

        <div class="mt-10">
          <a
            href="/gallery"
            class="inline-flex items-center justify-center
            bg-[#2F4340] text-white font-bold
            px-8 py-3.5 rounded-xl shadow-md
            hover:bg-[#D9744B]
            transition-colors duration-200"
          >
            Explore Our Project Gallery
          </a>
        </div>
      </div>
    </section>
  </main>
</div>