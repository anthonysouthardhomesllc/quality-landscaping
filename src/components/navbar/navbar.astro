---
// navbar.astro
// Main navigation component with optimized local brand image rendering and clean semantic structures

import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Image } from 'astro:assets';

// Import local logo asset for automatic WebP format rendering and build-time optimization
import logoImg from "@assets/logos/logo.jpg";

const menuitems: Array<{ title: string; path: string; children?: Array<{ title: string; path: string }> }> = [
  {
    title: "Home",
    path: "/",
  },
  {
    title: "About Us",
    path: "/about/",
  },
  {
    title: "Services",
    path: "/services/",
  },
  {
    title: "Gallery",
    path: "/gallery/",
  },
  {
    title: "Contact",
    path: "/contact/",
  }
];
---

<div class="w-full bg-[#D1D5BE]/90">
  <div class="px-6">
    <header class="max-w-5xl mx-auto flex flex-col lg:flex-row justify-between items-center py-2">
      <Astronav>
        
        <!-- Logo Section and Mobile Menu Trigger -->
        <div class="flex w-full lg:w-auto items-center justify-between px-4 lg:px-0">
          <a 
            href="/" 
            class="flex items-center hover:scale-110 duration-500" 
            id="logo-link"
            aria-label="Quality Landscape and Leisure Home"
          >
            <Image 
              src={logoImg}
              width={80}
              height={80}
              class="h-20 w-auto object-contain brightness-115 rounded-full opacity-80" 
              alt="Quality Landscape and Leisure Logo" 
              id="logo"
              loading="eager" 
            />
          </a>
          <div class="block lg:hidden">
            <MenuIcon class="w-8 h-8 text-[#2F4340] hover:text-[#2F4340] transition-colors" />
          </div>
        </div>
        
        <!-- Collapsible Navigation Area -->
        <MenuItems class="hidden lg:flex lg:items-center w-full lg:w-auto mt-4 lg:mt-0 pb-4 lg:pb-0">
          <nav class="w-full" aria-label="Main Navigation">
            <ul class="flex flex-col items-end lg:flex-row lg:items-center gap-2 lg:gap-6 px-4 lg:px-0">
              {
                menuitems.map((item, index) => (
                  <>
                    {item.children && (
                      <Dropdown
                        title={item.title}
                        children={item.children}
                        lastItem={index === menuitems.length - 1}
                      />
                    )}

                    {!item.children && (
                      <li>
                        <a
                          href={item.path}
                          class="flex py-2 items-center text-[#2F4340] hover:text-[#D9744B] font-medium transition-colors"
                        >
                          <span>{item.title}</span>
                        </a>
                      </li>
                    )}
                  </>
                ))
              }
            </ul>
          </nav>
        </MenuItems>
          
      </Astronav>
    </header>
  </div>
</div>

<style>
  #logo-link:hover #logo {
    border-color: #2F4340;
    border-width: 2px;
  }
</style>