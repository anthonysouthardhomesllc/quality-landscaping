---
// src/components/Welcome.astro
---

<div id="container" class="py-20 text-center">
  <main>
    <section id="hero" class="max-w-2xl mx-auto px-4">
      <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
        Quality Landscaping
      </h1>
      <p class="text-xl text-gray-700 mb-8">
        Transforming your outdoor space into a stunning oasis.
      </p>
      <div class="flex justify-center gap-4">
        <a href="#services" class="px-6 py-3 bg-gray-600 text-white font-medium rounded shadow
		 hover:bg-gray-800 transition">
          Our Services
        </a>
        <a href="#contact" class="px-6 py-3 bg-white text-gray-700 font-medium rounded shadow border
		 border-gray-600 hover:bg-gray-300 hover:border-gray-900 transition">
          Contact Us
        </a>
      </div>
    </section>
  </main>
</div>