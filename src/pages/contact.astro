---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Container from "@components/container.astro";
---

<Layout title="Contact Quality Landscaping">
  <Container>
    <div class="py-12 md:py-24 max-w-3xl mx-auto px-4">
      
      <!-- Main Centered Content Card (Added z-10 and pointer-events-auto to override rogue layouts) -->
      <section class="relative z-10 pointer-events-auto bg-[#D1D5BE]/60 backdrop-blur-md rounded-3xl p-8 md:p-12 shadow-xl border border-white/40 text-center">
        
        <!-- Header Section -->
        <header class="max-w-2xl mx-auto mb-10">
          <h1 class="text-4xl md:text-5xl font-extrabold text-[#2F4340] tracking-tight mb-4">
            Get In Touch
          </h1>
          <p class="text-lg text-slate-800 font-medium leading-relaxed">
            Have questions about our landscaping or hardscaping services? We're here to bring your outdoor vision to life.
          </p>
        </header>

        <!-- Centered Stacked Contact Information -->
        <div class="max-w-md mx-auto space-y-6 my-8 text-left">
          
          <!-- Phone Row -->
          <div class="flex items-center gap-5 bg-white/40 p-4 rounded-2xl border border-white/40 shadow-sm hover:border-[#2F4340]">
            <!-- Clickable Phone Icon wrapper -->
            <a href="tel:812-244-9432" class="bg-white p-3 rounded-xl shadow-sm text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-colors duration-200 shrink-0 block cursor-pointer">
              <!-- pointer-events-none ensures the click triggers the anchor tag -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 pointer-events-none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 0 1-7.108-7.108c-.155-.44.011-.927.387-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </a>
            <div>
              <h3 class="text-xs uppercase font-bold tracking-wider text-slate-600 mb-0.5">Call Us</h3>
              <a href="tel:812-244-9432" class="text-xl font-extrabold text-[#2F4340] hover:text-[#D9744B] transition-colors duration-200 block cursor-pointer">
                812-244-9432
              </a>
            </div>
          </div>

          <!-- Email Row -->
          <div class="flex items-center gap-5 bg-white/40 p-4 rounded-2xl border border-white/40 shadow-sm hover:border-[#2F4340]">
            <!-- Clickable Email Icon wrapper -->
            <a href="mailto:quadup79@gmail.com" class="bg-white p-3 rounded-xl shadow-sm text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-colors duration-200 shrink-0 block cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 pointer-events-none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </a>
            <div class="break-all">
              <h3 class="text-xs uppercase font-bold tracking-wider text-slate-600 mb-0.5">Email Us</h3>
              <a href="mailto:quadup79@gmail.com" class="text-lg font-bold text-[#2F4340] hover:text-[#D9744B] transition-colors duration-200 block cursor-pointer">
                quadup79@gmail.com
              </a>
            </div>
          </div>

          <!-- Address Row -->
          <div class="flex items-center gap-5 bg-white/40 p-4 rounded-2xl border border-white/40 shadow-sm hover:border-[#2F4340]">
            <!-- Clickable Address Icon wrapper -->
            <a 
              href="https://www.google.com/maps/place/Quality+Roofing+of+Indiana+LLC/@39.506166,-87.3578661,16.08z" 
              target="_blank" 
              rel="noopener noreferrer"
              class="bg-white p-3 rounded-xl shadow-sm text-[#2F4340] hover:bg-[#2F4340] hover:text-white transition-colors duration-200 shrink-0 block cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </a>
            <div>
              <h3 class="text-xs uppercase font-bold tracking-wider text-slate-600 mb-0.5">Visit Our Office</h3>
              <a 
                href="https://www.google.com/maps/place/Quality+Roofing+of+Indiana+LLC/@39.506166,-87.3578661,16.08z" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-lg font-bold text-[#2F4340] hover:text-[#D9744B] transition-colors duration-200 block leading-snug cursor-pointer"
              >
                3601 N. Fruitridge Avenue<br />
                Terre Haute, IN 47805
              </a>
            </div>
          </div>

        </div>

        <!-- Bottom Footer Note -->
        <div class="mt-10 pt-6 border-t border-dashed border-[#2F4340]/30 text-base text-[#2F4340] font-semibold italic">
          We look forward to connecting and planning your project!
        </div>
        
      </section>
    </div>
  </Container>
</Layout>