---
//Layout.astro
//Core layout wrapper handling site SEO, global styles, and shared shell components (Navbar/Footer)

import { SEO } from "astro-seo";
import { Image } from 'astro:assets';
import FooterContent from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import background from "@assets/background.webp"; 
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

//Component Props & Fallbacks
const { 
  title, 
  description = "Quality Landscape and Leisure provides premium residential and commercial landscaping, lawn care, and custom hardscaping services across Terre Haute and the Wabash Valley.",
  canonical
} = Astro.props;

//URL Management for Search & Social Networks
//Automatically generates absolute links based on your production 'site' URL configuration
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.jpg", Astro.site).toString();

//Dynamic Title Formatting
//Prevents duplicating the business name if a page explicitly includes it (e.g., in the gallery)
const isBrandAppended = title.includes("Quality Landscape");
const makeTitle = title
  ? (isBrandAppended ? title : `${title} | Quality Landscape & Leisure`)
  : "Quality Landscape and Leisure | Landscaping Services in Terre Haute, Indiana"; 
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Base Browser Meta -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Search Engine & Open Graph Optimization Wrapper -->
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{ 
        creator: "@qualitylandscapeandleisure",
        site: "qualitylandscapeandleisure.com",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Quality Landscape and Leisure - Terre Haute, IN",
        },
      }}
    />
  </head>

  <body class="flex flex-col min-h-screen relative overflow-x-hidden">
    
    <!-- Visual Enhancements: Global Full-Bleed Fixed Background -->
    <!-- Performance Optimization: content-visibility updates rendering performance during glassmorphism scrolling -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden scale-105 z-0" style="content-visibility: auto;">
      <Image 
        src={background} 
        alt="Quality Landscape project background showcasing stone and turf integration" 
        widths={[640, 1200, 1920]} 
        sizes="100vw"
        class="w-full h-full object-cover select-none pointer-events-none"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <!-- UI Composition Container (Keeps footer pinned cleanly on shorter pages) -->
    <div class="relative z-10 flex flex-col min-h-screen grow">
      <Navbar />
      
      <!-- Primary Page Content Area -->
      <main class="grow">
        <slot />
      </main>

      <FooterContent />
    </div>
  </body>
</html>